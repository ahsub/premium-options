// ── Finnhub API Helper ────────────────────────────────────────
const FINNHUB_BASE = 'https://finnhub.io/api/v1';
const RATE_LIMIT_MS = 1100; // 60/min = 1 call/sec + buffer

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

async function finnhubGet(endpoint, params, apiKey) {
  const url = new URL(FINNHUB_BASE + endpoint);
  Object.entries(params).forEach(([k,v]) => url.searchParams.set(k, v));
  url.searchParams.set('token', apiKey);
  const r = await fetch(url.toString());
  if (!r.ok) throw new Error(`Finnhub ${r.status}: ${endpoint}`);
  return r.json();
}

// ── Cache Layer ───────────────────────────────────────────────
const CACHE_KEY = 'premium_options_screener_cache';
const CACHE_TTL = 24 * 60 * 60 * 1000; // 24h

function loadCache() {
  try {
    const raw = localStorage.getItem(CACHE_KEY);
    if (!raw) return null;
    const { ts, data } = JSON.parse(raw);
    if (Date.now() - ts > CACHE_TTL) return null;
    return data;
  } catch { return null; }
}

function saveCache(data) {
  try {
    localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data }));
  } catch(e) { console.warn('Cache save failed:', e); }
}

function clearCache() {
  localStorage.removeItem(CACHE_KEY);
}

// ── Main Screener ─────────────────────────────────────────────
async function runFullScreener(params, apiKey, onProgress, onResult) {
  // Check cache first
  const cached = loadCache();
  if (cached && !params.forceRefresh) {
    onProgress({ phase: 'cache', pct: 100, msg: `Cache geladen (${cached.length} Aktien, max. 24h alt)` });
    return applyFilters(cached, params);
  }

  // No Finnhub key → use curated list
  if (!apiKey) {
    onProgress({ phase: 'fallback', pct: 100, msg: 'Kein Finnhub-Key → kuratierte 50er-Liste' });
    return applyFilters(CURATED_50.map(s => ({...s, score: calcScore(s)})), params);
  }

  const universe = FULL_UNIVERSE;
  const total = universe.length;
  let processed = 0;
  let passed1 = []; // survived price filter
  let results = [];
  const BATCH = 5; // 5 parallel calls

  // ── Phase 1: Quote filter (price $15-$80) ──
  onProgress({ phase: 1, pct: 0, msg: `Phase 1/2: Kurs-Filter (${total} Ticker)...` });

  for (let i = 0; i < universe.length; i += BATCH) {
    const batch = universe.slice(i, i + BATCH);
    const promises = batch.map(sym =>
      finnhubGet('/quote', { symbol: sym }, apiKey)
        .then(q => ({ sym, price: q.c || 0, change: q.dp || 0 }))
        .catch(() => ({ sym, price: 0 }))
    );
    const quotes = await Promise.all(promises);
    processed += batch.length;

    quotes.forEach(q => {
      if (q.price >= 15 && q.price <= 80) {
        passed1.push({ t: q.sym, price: q.price, priceChange: q.change });
      }
    });

    const pct = Math.round(processed / total * 50);
    onProgress({
      phase: 1, pct,
      msg: `Phase 1: ${processed}/${total} Ticker geprüft — ${passed1.length} im Kursbereich $15–$80`
    });
    await sleep(RATE_LIMIT_MS);
  }

  // ── Phase 2: Fundamentals ──
  onProgress({ phase: 2, pct: 50, msg: `Phase 2/2: Fundamentaldaten (${passed1.length} Kandidaten)...` });

  let fundProcessed = 0;
  for (let i = 0; i < passed1.length; i += BATCH) {
    const batch = passed1.slice(i, i + BATCH);
    const promises = batch.map(async s => {
      try {
        const [basic, profile, metric] = await Promise.all([
          finnhubGet('/stock/metric', { symbol: s.t, metric: 'all' }, apiKey),
          finnhubGet('/stock/profile2', { symbol: s.t }, apiKey),
          finnhubGet('/stock/basic-financials', { symbol: s.t, metric: 'all' }, apiKey)
            .catch(() => null),
        ]);

        const m = basic.metric || {};
        const p = profile || {};

        return {
          t: s.t,
          name: p.name || s.t,
          price: s.price,
          priceChange: s.priceChange,
          pe: m.peNormalizedAnnual || m.peTTM || 0,
          payout: m.payoutRatioAnnual ? m.payoutRatioAnnual * 100 : 0,
          divYield: m.dividendYieldIndicatedAnnual ? m.dividendYieldIndicatedAnnual : 0,
          divGrowth: m['5YDivGrowthRate'] || m['3YDivGrowthRate'] || 0,
          divStreak: 0, // nicht direkt via API → aus kuratierter Liste ergänzt
          fcfCoverage: m.freeCashFlowTTM > 0 ? (m.freeCashFlowTTM / Math.max(1, m.dividendPerShareAnnual * (p.shareOutstanding||0) * 1e6)) : 0,
          fcf: (m.freeCashFlowTTM || 0) > 0,
          revenue: (m['10YRevenueGrowthRate'] || m['5YRevenueGrowthRate'] || 0) > 0,
          weeklies: true, // assume true for large caps, will be corrected by option chain
          buyback: (m.roeTTM || 0) > 10, // proxy: high ROE often correlates with buybacks
          rsi: 50, // placeholder — no RSI from basic API, use chart tab
          macd: false, // placeholder
          support: s.price * 0.97,
          resist: s.price * 1.05,
          iv: estimateIV(m.beta || 1, m['52WeekPriceReturnDaily'] || 0),
          industry: p.finnhubIndustry || '',
          marketCap: p.marketCapitalization || 0,
        };
      } catch(e) {
        return null;
      }
    });

    const batch_results = (await Promise.all(promises)).filter(Boolean);
    results.push(...batch_results);
    fundProcessed += batch.length;

    const pct = 50 + Math.round(fundProcessed / passed1.length * 50);
    onProgress({
      phase: 2, pct,
      msg: `Phase 2: ${fundProcessed}/${passed1.length} Fundamentaldaten geladen — ${results.length} Kandidaten`
    });
    await sleep(RATE_LIMIT_MS);
  }

  // Supplement with curated data for divStreak (not in API)
  const curatedMap = Object.fromEntries(CURATED_50.map(s => [s.t, s]));
  results = results.map(s => {
    const c = curatedMap[s.t];
    if (c) {
      s.divStreak = c.divStreak || 0;
      s.macd = c.macd;
      s.rsi = c.rsi;
    }
    return { ...s, score: calcScore(s) };
  });

  saveCache(results);
  onProgress({ phase: 'done', pct: 100, msg: `Screening abgeschlossen — ${results.length} Aktien analysiert` });
  return applyFilters(results, params);
}

// ── IV-Schätzung aus Beta ─────────────────────────────────────
function estimateIV(beta, annualReturn) {
  // Grobe Schätzung: IV ≈ Beta × 20% + Basis
  const base = 15;
  const est = base + beta * 10 + Math.abs(annualReturn) * 0.1;
  return Math.min(70, Math.max(10, Math.round(est)));
}

// ── Filter anwenden ───────────────────────────────────────────
function applyFilters(stocks, params) {
  return stocks.filter(s => {
    if (!s) return false;
    if (s.price < (params.pmin||15) || s.price > (params.pmax||80)) return false;
    if (params.peMax && s.pe > params.peMax) return false;
    if (s.iv < (params.ivMin||20) || s.iv > (params.ivMax||50)) return false;
    if (params.payoutMax && s.payout > params.payoutMax) return false;
    if (params.needFcf && !s.fcf) return false;
    if (params.needRevenue && !s.revenue) return false;
    if (params.needWeeklies && !s.weeklies) return false;
    if (params.needBuyback && !s.buyback) return false;
    // Dividend filters
    const y = s.divYield || 0;
    if (params.divYield === 'lt2'   && y >= 2)          return false;
    if (params.divYield === '2to4'  && (y < 2 || y > 4)) return false;
    if (params.divYield === 'gt4'   && y <= 4)           return false;
    if (params.divYield === 'none'  && y > 0)            return false;
    const g = s.divGrowth || 0;
    if (params.divGrowth === 'lt2'  && g >= 2)           return false;
    if (params.divGrowth === '2to5' && (g < 2 || g > 5)) return false;
    if (params.divGrowth === 'gt5'  && g <= 5)           return false;
    return true;
  }).sort((a, b) => (b.score||0) - (a.score||0));
}

// ── Score-Berechnung (identisch mit index.html) ───────────────
function calcScore(s) {
  let base = 0;
  if (s.revenue) base += 1;
  if (s.fcf)     base += 1;
  if ((s.pe||0) <= 20)  base += 1; else if ((s.pe||0) <= 25) base += 0.5;
  if ((s.payout||0) <= 60) base += 0.5;
  if (s.buyback) base += 0.5;
  if (s.weeklies) base += 0.5;
  if ((s.iv||0) >= 20 && (s.iv||0) <= 50) base += 1;
  if (s.price >= 15 && s.price <= 80) base += 0.5;
  if ((s.rsi||50) < 70 && (s.rsi||50) > 30) base += 0.5;
  if (s.macd) base += 0.5;
  // Dividend bonus
  const y = s.divYield || 0;
  if (y >= 2 && y <= 4) base += 0.5;
  else if (y > 4)       base += 0.3;
  else if (y >= 1)      base += 0.2;
  const g = s.divGrowth || 0;
  if (g > 5)      base += 0.6;
  else if (g >= 2) base += 0.3;
  return Math.min(10, base);
}

// ── Exports ───────────────────────────────────────────────────
window.ScreenerEngine = {
  runFullScreener,
  applyFilters,
  calcScore,
  FULL_UNIVERSE,
  CURATED_50,
  DOW30,
  NASDAQ100,
  clearCache,
  loadCache,
}
